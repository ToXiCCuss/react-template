{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:mavenPropertyVersions",
    ":prConcurrentLimitNone",
    ":prHourlyLimitNone",
    "security:minimumReleaseAgeNpm"
  ],
  "helmv3": {
    "enabled": false
  },
  "automerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "groupName": "all major-updates"
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "groupName": "all minor and patch updates"
    }
  ],
  "ignoreTests": true,
  "maven": {
    "ignoreDeps": [
      "de.rjst:react-template",
      "de.rjst:frontend-template-frontend"
    ]
  }
}
